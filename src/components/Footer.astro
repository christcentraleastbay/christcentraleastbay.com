---
import { site, service, contact, nav } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-stone-900/10 bg-stone-50 dark:border-stone-100/10 dark:bg-stone-950">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:grid-cols-2 sm:px-6 lg:grid-cols-3">
    <div>
      <p class="font-serif text-xl font-bold uppercase tracking-tight">{site.name}</p>
      <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">{site.tagline}</p>
    </div>

    <div class="text-sm">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-stone-500 dark:text-stone-400">
        Join us {service.day}s
      </p>
      <p class="mt-3">{service.time}</p>
      <p>
        <a href={service.mapsUrl} class="link-inline">{service.address}</a>
      </p>
      <p class="mt-1 text-stone-500 dark:text-stone-400">{service.kidsNote}</p>
    </div>

    <div class="text-sm">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-stone-500 dark:text-stone-400">Get in touch</p>
      <p class="mt-3">
        <a href={`mailto:${contact.email}`} class="link-inline">{contact.email}</a>
      </p>
      <p class="mt-1">
        <a href={contact.instagramUrl} class="link-inline">{contact.socialHandle}</a>
      </p>
      <nav class="mt-5" aria-label="Footer">
        <ul class="flex flex-wrap gap-x-5 gap-y-1">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="text-xs font-semibold uppercase tracking-widest text-stone-500 hover:text-stone-950 dark:text-stone-400 dark:hover:text-stone-50">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
  <div class="border-t border-stone-900/10 py-4 text-center text-xs text-stone-500 dark:border-stone-100/10 dark:text-stone-400">
    © {year} {site.name}
  </div>
</footer>
