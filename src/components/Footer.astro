---
import { site, service, contact, nav } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="bg-sea-900 text-stone-100">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:grid-cols-2 sm:px-6 lg:grid-cols-3">
    <div>
      <p class="font-serif text-xl font-bold uppercase tracking-wide text-teal-200">{site.name}</p>
      <p class="mt-2 text-sm text-stone-100/70">{site.tagline}</p>
    </div>

    <div class="text-sm">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-sand-300">
        Join us {service.day}s
      </p>
      <p class="mt-3">{service.time}</p>
      <p>
        <a href={service.mapsUrl} class="text-teal-200 underline underline-offset-4 hover:text-accent-200">{service.address}</a>
      </p>
      <p class="mt-1 text-stone-100/70">{service.kidsNote}</p>
    </div>

    <div class="text-sm">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-sand-300">Get in touch</p>
      <p class="mt-3">
        <a href={`mailto:${contact.email}`} class="text-teal-200 underline underline-offset-4 hover:text-accent-200">{contact.email}</a>
      </p>
      <p class="mt-1">
        <a href={contact.instagramUrl} class="text-teal-200 underline underline-offset-4 hover:text-accent-200">{contact.socialHandle}</a>
      </p>
      <nav class="mt-5" aria-label="Footer">
        <ul class="flex flex-wrap gap-x-4 gap-y-1">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="text-stone-100/70 hover:text-stone-50 hover:underline">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
  <div class="border-t border-stone-100/10 py-4 text-center text-xs text-stone-100/60">
    © {year} {site.name}
  </div>
</footer>
