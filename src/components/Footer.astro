---
import { site, service, contact, nav } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-stone-300/60 bg-stone-100 dark:border-stone-700/60 dark:bg-stone-900">
  <div class="mx-auto grid max-w-5xl gap-10 px-4 py-14 sm:grid-cols-2 sm:px-6 lg:grid-cols-3">
    <div>
      <p class="text-lg font-bold tracking-tight text-stone-900 dark:text-stone-100">{site.name}</p>
      <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">{site.tagline}</p>
    </div>

    <div class="text-sm">
      <p class="eyebrow !text-xs">Join us {service.day}s</p>
      <p class="mt-3">{service.time}</p>
      <p>
        <a href={service.mapsUrl} class="link-inline">{service.address}</a>
      </p>
      <p class="mt-1 text-stone-500 dark:text-stone-400">{service.kidsNote}</p>
    </div>

    <div class="text-sm">
      <p class="eyebrow !text-xs">Get in touch</p>
      <p class="mt-3">
        <a href={`mailto:${contact.email}`} class="link-inline">{contact.email}</a>
      </p>
      <p class="mt-1">
        <a href={contact.instagramUrl} class="link-inline">{contact.socialHandle}</a>
      </p>
      <nav class="mt-5" aria-label="Footer">
        <ul class="flex flex-wrap gap-x-4 gap-y-1">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="text-stone-500 hover:text-accent-700 hover:underline dark:text-stone-400 dark:hover:text-accent-200">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
  <div class="border-t border-stone-300/40 py-4 text-center text-xs text-stone-500 dark:border-stone-700/40 dark:text-stone-400">
    © {year} {site.name}
  </div>
</footer>
