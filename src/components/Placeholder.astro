---
/**
 * Self-contained media placeholder: labeled hatch block, no external
 * requests. Swap for real photography/video later by replacing usages
 * with <img>/<video> — the aspect prop mirrors common media ratios.
 */
interface Props {
  label: string;
  aspect?: '16/9' | '4/3' | '1/1' | '21/9';
  class?: string;
}

const { label, aspect = '16/9', class: className } = Astro.props;
const aspectClass = {
  '16/9': 'aspect-video',
  '4/3': 'aspect-4/3',
  '1/1': 'aspect-square',
  '21/9': 'aspect-[21/9]',
}[aspect];
---

<figure
  class:list={[
    'relative flex items-center justify-center overflow-hidden border border-stone-300 bg-stone-200 dark:border-stone-700 dark:bg-stone-800',
    aspectClass,
    className,
  ]}
  role="img"
  aria-label={`Placeholder: ${label}`}
>
  <svg class="absolute inset-0 h-full w-full text-stone-300 dark:text-stone-700" aria-hidden="true">
    <defs>
      <pattern id="hatch" width="12" height="12" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
        <line x1="0" y="0" x2="0" y2="12" stroke="currentColor" stroke-width="1"></line>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#hatch)"></rect>
  </svg>
  <figcaption class="relative z-10 bg-stone-50/90 px-4 py-2 text-xs font-semibold uppercase tracking-widest text-stone-500 dark:bg-stone-900/90 dark:text-stone-400">
    {label}
  </figcaption>
</figure>
