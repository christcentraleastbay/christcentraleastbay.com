---
import { site } from '../data/site';
import Video from './Video.astro';

const ctas = [
  { label: 'Plan Your Visit', href: '/im-new', primary: true },
  { label: 'Hear the Word', href: '/resources', primary: false },
  { label: 'Get Connected', href: '/connect', primary: false },
];
---

<section class="border-b border-stone-300 dark:border-stone-700">
  <div class="mx-auto max-w-4xl px-4 pb-12 pt-20 text-center sm:px-6 sm:pt-24">
    <p class="text-sm font-semibold text-stone-500 dark:text-stone-400">Welcome to {site.name}</p>
    <h1 class="mt-4 text-4xl font-bold leading-tight sm:text-5xl">
      {site.tagline}
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-stone-600 dark:text-stone-300">
      {site.subtext}
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      {ctas.map((cta) => <a href={cta.href} class={cta.primary ? 'btn' : 'btn-outline'}>{cta.label}</a>)}
    </div>
  </div>
  <div class="mx-auto max-w-5xl px-4 pb-16 sm:px-6">
    <div class="media-frame aspect-[21/9]">
      <Video base="/media/hero" label="Sunday worship at Christ Central East Bay" />
    </div>
  </div>
</section>
