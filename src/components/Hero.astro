---
import { site } from '../data/site';
import Video from './Video.astro';

const ctas = [
  { label: 'Plan Your Visit', href: '/im-new', primary: true },
  { label: 'Hear the Word', href: '/#resources', primary: false },
  { label: 'Get Connected', href: '/connect', primary: false },
];
---

<section class="border-b border-stone-200 bg-stone-100 dark:border-stone-800 dark:bg-stone-900">
  <div class="mx-auto max-w-4xl px-4 pb-14 pt-24 text-center sm:px-6 sm:pb-16 sm:pt-32">
    <p class="eyebrow">Welcome to {site.name}</p>
    <div class="mx-auto mt-5 h-1 w-12 rounded-full bg-accent-600" aria-hidden="true"></div>
    <h1 class="mt-6 text-4xl font-bold leading-tight tracking-tight text-stone-900 sm:text-6xl dark:text-stone-100">
      {site.tagline}
    </h1>
    <p class="mx-auto mt-7 max-w-2xl text-lg leading-relaxed text-stone-600 dark:text-stone-300">
      {site.subtext}
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      {ctas.map((cta) => <a href={cta.href} class={cta.primary ? 'btn' : 'btn-outline'}>{cta.label}</a>)}
    </div>
  </div>
  <div class="mx-auto max-w-5xl px-4 pb-20 sm:px-6">
    <div class="media-frame aspect-[21/9]">
      <Video base="/media/hero" label="Sunday worship at Christ Central East Bay" />
    </div>
  </div>
</section>
