---
import { site } from '../data/site';
import Video from './Video.astro';

const ctas = [
  { label: 'Plan Your Visit', href: '/im-new', primary: true },
  { label: 'Hear the Word', href: '/#resources', primary: false },
  { label: 'Get Connected', href: '/connect', primary: false },
];
---

<section class="bg-stone-800 text-white">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-20 sm:px-6 sm:py-28 lg:grid-cols-[1.1fr_1fr]">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.25em] text-accent-200">
        Welcome to {site.name}
      </p>
      <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
        {site.tagline}
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-stone-300">
        {site.subtext}
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        {
          ctas.map((cta) => (
            <a
              href={cta.href}
              class:list={[
                'inline-block rounded-md px-7 py-3 text-sm font-bold transition-colors',
                cta.primary
                  ? 'bg-accent-200 text-stone-900 hover:bg-accent-100'
                  : 'border-2 border-stone-500 text-stone-200 hover:border-accent-200 hover:text-accent-200',
              ]}
            >
              {cta.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="aspect-video overflow-hidden rounded-xl ring-1 ring-stone-600">
      <Video base="/media/hero" label="Sunday worship at Christ Central East Bay" />
    </div>
  </div>
</section>
