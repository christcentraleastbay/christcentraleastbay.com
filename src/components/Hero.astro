---
import { site } from '../data/site';
import Video from './Video.astro';

const ctas = [
  { label: 'Plan Your Visit', href: '/im-new', primary: true },
  { label: 'Hear the Word', href: '/#resources', primary: false },
  { label: 'Get Connected', href: '/connect', primary: false },
];
---

<section>
  <div class="mx-auto max-w-7xl px-4 pb-10 pt-20 sm:px-6 sm:pt-28">
    <p class="text-xs font-bold uppercase tracking-[0.3em] text-stone-500 dark:text-stone-400">
      Welcome to {site.name}
    </p>
    <h1 class="mt-6 font-serif text-6xl font-bold uppercase leading-[0.95] tracking-tight text-stone-950 sm:text-8xl lg:text-9xl dark:text-stone-50">
      {site.tagline}
    </h1>
    <div class="mt-10 flex max-w-5xl flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <p class="max-w-xl text-lg leading-relaxed text-stone-600 dark:text-stone-300">
        {site.subtext}
      </p>
      <div class="flex flex-wrap gap-3">
        {ctas.map((cta) => <a href={cta.href} class={cta.primary ? 'btn' : 'btn-outline'}>{cta.label}</a>)}
      </div>
    </div>
  </div>
  <div class="mx-auto max-w-7xl px-4 pb-16 sm:px-6">
    <div class="media-frame aspect-[21/9]">
      <Video base="/media/hero" label="Sunday worship at Christ Central East Bay" />
    </div>
  </div>
</section>
