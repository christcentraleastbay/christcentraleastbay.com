---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="bg-stone-950 dark:bg-stone-100">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 sm:py-28">
    <h2 class="max-w-4xl font-serif text-5xl font-bold uppercase leading-[0.95] tracking-tight text-stone-50 sm:text-7xl dark:text-stone-950">
      {heading}
    </h2>
    <p class="mt-6 max-w-xl text-lg text-stone-400 dark:text-stone-600">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a
      href={buttonHref}
      class="mt-10 inline-block border-2 border-stone-50 bg-stone-50 px-8 py-3.5 text-xs font-bold uppercase tracking-[0.2em] text-stone-950 transition-colors hover:bg-transparent hover:text-stone-50 dark:border-stone-950 dark:bg-stone-950 dark:text-stone-50 dark:hover:bg-transparent dark:hover:text-stone-950"
    >
      {buttonLabel}
    </a>
  </div>
</section>
