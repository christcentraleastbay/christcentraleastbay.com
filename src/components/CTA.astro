---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="relative bg-sea-800 dark:bg-sea-800">
  <svg class="block w-full rotate-180 text-stone-50 dark:text-sea-900" viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
    <path fill="currentColor" d="M0,32 C240,64 480,0 720,16 C960,32 1200,64 1440,32 L1440,60 L0,60 Z"></path>
  </svg>
  <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h2 class="font-serif text-3xl font-bold uppercase tracking-wide text-stone-50 sm:text-5xl">
      {heading}
    </h2>
    <p class="mt-4 text-lg text-teal-200">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a href={buttonHref} class="btn mt-8">{buttonLabel}</a>
  </div>
</section>
