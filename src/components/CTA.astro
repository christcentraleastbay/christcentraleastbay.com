---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="bg-stone-800">
  <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-5xl">
      {heading}
    </h2>
    <p class="mt-4 text-lg text-stone-300">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a
      href={buttonHref}
      class="mt-8 inline-block rounded-md bg-accent-200 px-8 py-3.5 text-sm font-bold text-stone-900 transition-colors hover:bg-accent-100"
    >
      {buttonLabel}
    </a>
  </div>
</section>
