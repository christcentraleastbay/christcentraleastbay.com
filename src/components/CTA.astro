---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="bg-accent-800">
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 sm:py-24">
    <h2 class="text-3xl font-bold leading-snug tracking-tight text-stone-50 sm:text-4xl">
      {heading}
    </h2>
    <div class="mx-auto mt-5 h-1 w-12 rounded-full bg-accent-200/70" aria-hidden="true"></div>
    <p class="mt-6 text-lg text-accent-100">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a
      href={buttonHref}
      class="mt-9 inline-block rounded-lg bg-stone-50 px-8 py-3 text-sm font-semibold text-accent-800 shadow-sm transition-colors hover:bg-accent-50"
    >
      {buttonLabel}
    </a>
  </div>
</section>
