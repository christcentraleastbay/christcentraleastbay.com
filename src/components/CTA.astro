---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="aurora relative overflow-hidden bg-stone-950">
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 sm:py-28">
    <h2 class="text-3xl font-extrabold tracking-tighter text-stone-50 sm:text-5xl">
      {heading}
    </h2>
    <p class="mt-5 text-lg text-stone-300">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a href={buttonHref} class="btn mt-9">{buttonLabel}</a>
  </div>
</section>
