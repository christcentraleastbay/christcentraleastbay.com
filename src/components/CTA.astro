---
interface Props {
  heading?: string;
  buttonLabel?: string;
  buttonHref?: string;
}

const {
  heading = 'We can’t wait to meet you.',
  buttonLabel = 'Plan Your Visit',
  buttonHref = '/im-new',
} = Astro.props;
---

<section class="bg-stone-900 dark:bg-stone-900">
  <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-20">
    <h2 class="font-serif text-3xl font-semibold tracking-tight text-stone-50 sm:text-4xl">
      {heading}
    </h2>
    <p class="mt-4 text-stone-300">
      <slot>Join us this Sunday — come as you are.</slot>
    </p>
    <a
      href={buttonHref}
      class="mt-8 inline-block rounded-full bg-accent-600 px-8 py-3 text-sm font-semibold text-white hover:bg-accent-700"
    >
      {buttonLabel}
    </a>
  </div>
</section>
