---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="rounded-xl border border-stone-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md dark:border-stone-700 dark:bg-stone-900">
  <div class="mb-4 h-1 w-10 rounded-full bg-accent-600" aria-hidden="true"></div>
  <h3 class="text-xl font-bold tracking-tight text-stone-900 dark:text-stone-100">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm font-medium text-accent-700 dark:text-accent-200">{subtitle}</p>}
  <div class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
