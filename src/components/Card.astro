---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="rounded-lg border border-stone-300 bg-white p-6 dark:border-stone-700 dark:bg-stone-900">
  <h3 class="text-xl font-bold">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm text-stone-500 dark:text-stone-400">{subtitle}</p>}
  <div class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
