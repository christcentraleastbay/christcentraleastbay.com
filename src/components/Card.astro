---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="rounded-3xl bg-white p-7 shadow-md transition-all hover:-translate-y-1 hover:shadow-xl dark:bg-sea-800">
  <div class="mb-4 h-2 w-12 rounded-full bg-accent-600" aria-hidden="true"></div>
  <h3 class="font-serif text-xl font-bold uppercase tracking-wide text-sea-800 dark:text-stone-50">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm font-semibold text-teal-600 dark:text-teal-200">{subtitle}</p>}
  <div class="mt-3 leading-relaxed text-stone-600 dark:text-stone-100/80">
    <slot />
  </div>
</div>
