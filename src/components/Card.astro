---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="glass rounded-3xl p-7 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-accent-600/10">
  <h3 class="text-xl font-bold tracking-tight text-stone-950 dark:text-stone-50">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm font-medium text-accent-600 dark:text-accent-200">{subtitle}</p>}
  <div class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
