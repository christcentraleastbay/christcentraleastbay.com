---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="rounded-xl border-t-4 border-accent-600 bg-white p-6 shadow-lg dark:border-accent-200 dark:bg-stone-800">
  <h3 class="text-xl font-extrabold tracking-tight text-stone-800 dark:text-white">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm font-semibold text-accent-600 dark:text-accent-200">{subtitle}</p>}
  <div class="mt-3 leading-relaxed text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
