---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="border border-stone-900/15 bg-stone-50 p-7 transition-colors hover:border-stone-900 dark:border-stone-100/15 dark:bg-stone-950 dark:hover:border-stone-100">
  <h3 class="font-serif text-2xl font-bold uppercase tracking-tight text-stone-950 dark:text-stone-50">{title}</h3>
  {subtitle && <p class="mt-1 text-xs font-semibold uppercase tracking-widest text-stone-500 dark:text-stone-400">{subtitle}</p>}
  <div class="mt-4 leading-relaxed text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
