---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="rounded-xl border border-stone-200 bg-white p-6 shadow-sm dark:border-stone-800 dark:bg-stone-900">
  <h3 class="font-serif text-xl font-semibold text-stone-900 dark:text-stone-100">{title}</h3>
  {subtitle && <p class="mt-0.5 text-sm text-stone-500 dark:text-stone-400">{subtitle}</p>}
  <div class="mt-3 text-stone-600 dark:text-stone-300">
    <slot />
  </div>
</div>
