---
import { site, nav } from '../data/site';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 bg-stone-50/95 shadow-sm backdrop-blur dark:bg-sea-900/95">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="font-serif text-lg font-bold uppercase tracking-wide text-sea-800 sm:text-xl dark:text-teal-200" aria-label={`${site.name} home`}>
      {site.name}
    </a>

    <!-- CSS-only mobile menu: checkbox drives the panel via peer-checked -->
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />
    <label
      for="nav-toggle"
      class="cursor-pointer rounded-full p-2 hover:bg-stone-200 md:hidden dark:hover:bg-sea-800"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    <nav
      class="absolute left-0 right-0 top-full hidden bg-stone-50 px-4 pb-4 shadow-md peer-checked:block md:static md:block md:bg-transparent md:p-0 md:shadow-none dark:bg-sea-900 md:dark:bg-transparent"
      aria-label="Main"
    >
      <ul class="flex flex-col gap-1 pt-2 md:flex-row md:items-center md:gap-5 md:pt-0">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                class:list={[
                  'block rounded-full px-4 py-2 text-sm font-bold transition-colors md:px-3 md:py-1.5',
                  current === item.href
                    ? 'bg-teal-600/10 text-teal-600 dark:bg-teal-200/10 dark:text-teal-200'
                    : 'text-stone-700 hover:bg-stone-200 dark:text-stone-100 dark:hover:bg-sea-800',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-2 md:mt-0 md:pl-1">
          <a href="/im-new" class="btn !px-5 !py-2 !text-xs">Plan Your Visit</a>
        </li>
      </ul>
    </nav>
  </div>
</header>
