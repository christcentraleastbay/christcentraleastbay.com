---
import { site, nav } from '../data/site';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-3 z-40 px-3 sm:top-4 sm:px-6">
  <div class="glass mx-auto flex max-w-5xl items-center justify-between gap-4 rounded-full px-5 py-2.5 shadow-lg shadow-stone-950/5">
    <a href="/" class="text-base font-bold tracking-tight text-stone-900 sm:text-lg dark:text-stone-50" aria-label={`${site.name} home`}>
      {site.name}
    </a>

    <!-- CSS-only mobile menu: checkbox drives the panel via peer-checked -->
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />
    <label
      for="nav-toggle"
      class="cursor-pointer rounded-full p-2 hover:bg-stone-200/60 md:hidden dark:hover:bg-white/10"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    <nav
      class="glass absolute left-3 right-3 top-full mt-2 hidden rounded-3xl px-4 py-4 shadow-lg peer-checked:block md:static md:mt-0 md:block md:rounded-none md:border-0 md:bg-transparent md:p-0 md:shadow-none md:backdrop-blur-none dark:md:bg-transparent"
      aria-label="Main"
    >
      <ul class="flex flex-col gap-1 md:flex-row md:items-center md:gap-1">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                class:list={[
                  'block rounded-full px-4 py-2 text-sm font-medium transition-colors md:px-3 md:py-1.5',
                  current === item.href
                    ? 'bg-accent-600/10 text-accent-700 dark:bg-accent-200/10 dark:text-accent-200'
                    : 'text-stone-600 hover:bg-stone-200/60 hover:text-stone-900 dark:text-stone-300 dark:hover:bg-white/10 dark:hover:text-stone-50',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-2 md:ml-2 md:mt-0">
          <a href="/im-new" class="btn !px-5 !py-2 !text-xs">Plan Your Visit</a>
        </li>
      </ul>
    </nav>
  </div>
</header>
