---
import { site, nav } from '../data/site';

const current = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 bg-stone-800 text-white">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3.5 sm:px-6">
    <a href="/" class="text-lg font-extrabold tracking-tight sm:text-xl" aria-label={`${site.name} home`}>
      {site.name}
    </a>

    <!-- CSS-only mobile menu: checkbox drives the panel via peer-checked -->
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />
    <label
      for="nav-toggle"
      class="cursor-pointer rounded p-2 hover:bg-stone-700 md:hidden"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </label>

    <nav
      class="absolute left-0 right-0 top-full hidden bg-stone-800 px-4 pb-4 peer-checked:block md:static md:block md:bg-transparent md:p-0"
      aria-label="Main"
    >
      <ul class="flex flex-col gap-1 pt-2 md:flex-row md:items-center md:gap-6 md:pt-0">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={current === item.href ? 'page' : undefined}
                class:list={[
                  'block rounded px-3 py-2 text-sm font-semibold transition-colors md:px-1 md:py-1',
                  current === item.href
                    ? 'text-accent-200'
                    : 'text-stone-300 hover:text-white',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-2 md:mt-0 md:pl-2">
          <a href="/im-new" class="inline-block rounded-md bg-accent-200 px-5 py-2 text-sm font-bold text-stone-900 transition-colors hover:bg-accent-100">
            Plan Your Visit
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
