---
interface Props {
  eyebrow?: string;
  heading?: string;
  tinted?: boolean;
  center?: boolean;
}

const { eyebrow, heading, tinted = false, center = false } = Astro.props;
---

<section class:list={[tinted && 'bg-stone-100 dark:bg-stone-900']}>
  <div class:list={['mx-auto max-w-7xl px-4 py-16 sm:px-6 sm:py-24', center && 'text-center']}>
    {
      eyebrow && (
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-stone-500 dark:text-stone-400">
          {eyebrow}
        </p>
      )
    }
    {
      heading && (
        <h2 class="mt-3 font-serif text-4xl font-bold uppercase leading-none tracking-tight text-stone-950 sm:text-6xl dark:text-stone-50">
          {heading}
        </h2>
      )
    }
    <div class:list={[(eyebrow || heading) && 'mt-8']}>
      <slot />
    </div>
  </div>
</section>
