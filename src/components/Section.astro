---
interface Props {
  eyebrow?: string;
  heading?: string;
  tinted?: boolean;
  center?: boolean;
}

const { eyebrow, heading, tinted = false, center = false } = Astro.props;
---

<section class:list={[tinted && 'bg-stone-100 dark:bg-stone-900']}>
  <div class:list={['mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20', center && 'text-center']}>
    {
      eyebrow && (
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-accent-600 dark:text-accent-200">
          {eyebrow}
        </p>
      )
    }
    {
      heading && (
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight text-stone-800 sm:text-4xl dark:text-stone-100">
          {heading}
        </h2>
      )
    }
    <div class:list={[(eyebrow || heading) && 'mt-6']}>
      <slot />
    </div>
  </div>
</section>
