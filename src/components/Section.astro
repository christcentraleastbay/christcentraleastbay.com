---
interface Props {
  eyebrow?: string;
  heading?: string;
  tinted?: boolean;
  center?: boolean;
}

const { eyebrow, heading, tinted = false, center = false } = Astro.props;
---

<section class:list={[tinted && 'bg-accent-50/60 dark:bg-accent-900/10']}>
  <div class:list={['mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24', center && 'text-center']}>
    {
      eyebrow && (
        <p class="text-sm font-semibold tracking-wide text-accent-600 dark:text-accent-200">
          {eyebrow}
        </p>
      )
    }
    {
      heading && (
        <h2 class="mt-2 text-3xl font-extrabold tracking-tighter text-stone-950 sm:text-5xl dark:text-stone-50">
          {heading}
        </h2>
      )
    }
    <div class:list={[(eyebrow || heading) && 'mt-7']}>
      <slot />
    </div>
  </div>
</section>
