---
interface Props {
  eyebrow?: string;
  heading?: string;
  tinted?: boolean;
  center?: boolean;
}

const { eyebrow, heading, tinted = false, center = false } = Astro.props;
---

<section class:list={[tinted && 'bg-stone-100 dark:bg-stone-900']}>
  <div class:list={['mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20', center && 'text-center']}>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    {
      heading && (
        <h2 class="mt-2 text-3xl font-bold leading-snug tracking-tight text-stone-900 sm:text-4xl dark:text-stone-100">
          {heading}
        </h2>
      )
    }
    <div class:list={[(eyebrow || heading) && 'mt-6']}>
      <slot />
    </div>
  </div>
</section>
