---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import CTA from '../components/CTA.astro';
import { site, service, ministries } from '../data/site';

const featuredMinistries = ministries.slice(0, 3);
---

<BaseLayout>
  <Hero />

  <Section tinted center>
    <p class="mx-auto max-w-3xl text-lg leading-relaxed text-stone-700 dark:text-stone-300">
      {site.welcome}
    </p>
  </Section>

  <Section eyebrow="Join us this Sunday" heading="Service Info" center>
    <dl class="mx-auto grid max-w-3xl gap-6 sm:grid-cols-3">
      <div>
        <dt class="text-sm font-semibold uppercase tracking-wide text-stone-500 dark:text-stone-400">When</dt>
        <dd class="mt-1 text-lg font-medium">{service.day}s · {service.time}</dd>
      </div>
      <div>
        <dt class="text-sm font-semibold uppercase tracking-wide text-stone-500 dark:text-stone-400">Where</dt>
        <dd class="mt-1 text-lg font-medium">
          <a href={service.mapsUrl} class="link-inline">
            {service.address}
          </a>
        </dd>
      </div>
      <div>
        <dt class="text-sm font-semibold uppercase tracking-wide text-stone-500 dark:text-stone-400">Kids</dt>
        <dd class="mt-1 text-lg font-medium">{service.kidsNote}</dd>
      </div>
    </dl>
  </Section>

  <Section tinted eyebrow="Get connected" heading="Ministries">
    <div class="grid gap-6 md:grid-cols-3">
      {
        featuredMinistries.map((m) => (
          <Card title={m.name} subtitle={'fullName' in m ? m.fullName : undefined}>
            <p>{m.blurb}</p>
          </Card>
        ))
      }
    </div>
    <p class="mt-8 text-center">
      <a href="/connect" class="link-inline font-semibold">
        See all ministries →
      </a>
    </p>
  </Section>

  <CTA />
</BaseLayout>
